<?xml version="1.0" encoding="utf-8"?>
<!--
  AnimatedVectorDrawable for the splash screen.
  Animates the moto_track path's trimPathEnd from 0→1 (drawing the route)
  in 1 200 ms.  Compose's AnimatedImageVector toggles atEnd to loop the effect.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/moto_splash">

    <target android:name="moto_track">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="1200"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

</animated-vector>
