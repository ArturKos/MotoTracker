<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
    <!-- Concept A: splash-palette GPS route — cyan trail, white start ring, green end pin.
         Content scaled to ~66% and centred so nothing is clipped by the adaptive mask's safe zone. -->
    <group
        android:pivotX="256"
        android:pivotY="256"
        android:scaleX="0.66"
        android:scaleY="0.66">
        <!-- Route track (splash trail cyan #2DD4FF) -->
        <path
            android:pathData="M128,372 C176,300 150,232 214,236 C278,240 250,152 320,150 C356,149 372,168 388,150"
            android:strokeColor="#2DD4FF"
            android:strokeWidth="30"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <!-- Start marker: dark fill + white ring (circle cx=128 cy=372 r=24) -->
        <path
            android:pathData="M104,372 a24,24 0 1,0 48,0 a24,24 0 1,0 -48,0"
            android:fillColor="#101114"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="16" />
        <!-- End pin: green disc (circle cx=388 cy=150 r=40), splash pin #00E676 -->
        <path
            android:pathData="M348,150 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0"
            android:fillColor="#00E676" />
        <!-- End pin hole: dark centre (circle cx=388 cy=150 r=15) -->
        <path
            android:pathData="M373,150 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0"
            android:fillColor="#101114" />
    </group>
</vector>
