<?xml version="1.0" encoding="utf-8"?>
<!--
  Window background painted by the OS during cold-start (before the first
  Compose frame).  Fills the screen with the hero dark colour (#101114) and
  stretches the AE2 mountains layer full-canvas so the OS cold-start frame
  matches the Compose mountains layer exactly — no scale/position jump. (AE3)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 1: solid dark background matching the hero artwork surround -->
    <item android:drawable="@color/splash_hero_bg" />
    <!-- Layer 2: AE2 mountains layer, full-canvas fill; matches Compose SplashScreen t=0 -->
    <item
        android:gravity="fill"
        android:drawable="@drawable/splash_l_mountains" />
</layer-list>
