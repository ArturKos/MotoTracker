<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme. Full design-token theming is implemented in A2. -->
    <!-- AppCompat-derived parent required by AppCompatActivity; preserves NoActionBar + DayNight behaviour. -->
    <style name="Theme.MotoTracker" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!--
        Launch theme applied to MainActivity in the manifest.
        Sets windowBackground to the branded dark splash drawable so the OS
        paints the cockpit colour + moto mark during process start — before
        the first Compose frame — eliminating the cold-start white flash.
        MainActivity.onCreate swaps back to Theme.MotoTracker immediately so
        the running app is unaffected.
    -->
    <style name="Theme.MotoTracker.Launch" parent="Theme.MotoTracker">
        <item name="android:windowBackground">@drawable/splash_window_background</item>
    </style>
</resources>
