# Copy to /etc/mototracker/snap.env (root:www-data 640) and fill in.
# Read by snap-interpolate.service via EnvironmentFile=.

DB_HOST=localhost
DB_USER=gps_db_dbuser
DB_PASS=<DB password from /var/www/html/gpstrack/gps_track_config.php>
DB_NAME=gps_db_data

OSRM_URL=http://127.0.0.1:5001

# How far back to scan each run. 60 min catches late arrivals and
# covers the case where OSRM was down for a cycle.
LOOKBACK_MINUTES=60

# OSRM /match hard-limits at 100; don't raise.
MATCH_BATCH_SIZE=100

# Gap in seconds that starts a new ride within the same device.
RIDE_GAP_SECONDS=1800

# Interpolation guardrails.
MIN_GAP_M=40
MAX_GAP_M=5000
POINT_SPACING_M=25
MAX_POINTS_PER_GAP=10
MAX_ROUTE_RATIO=3.0
MAX_PAIR_SECONDS=900

# DRY_RUN=1 → log what would happen, don't write.
DRY_RUN=0
